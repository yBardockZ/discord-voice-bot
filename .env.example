# ==============================================================================
# DATABASE CONFIGURATION (POSTGRES)
# ==============================================================================
# Host: On Docker, use the service name (db). On IntelliJ (local), use localhost.
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASS=

# ==============================================================================
# DISCORD CONFIGURATION
# ==============================================================================
# Token obtained from the Discord Developer Portal
BOT_TOKEN=

# ==============================================================================
# CONFIGURAÇÕES DO SPRING / FLYWAY
# ==============================================================================
# Sets Spring / Flyway behavior
SPRING_PROFILES_ACTIVE=default
FLYWAY_ENABLED=true